{
  "name": "@sthira/chunked",
  "version": "1.0.0",
  "description": "Size-aware virtual store chunking for Sthira",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sthira/core": ">=0.2.0",
    "@sthira/persist": ">=1.0.0"
  },
  "devDependencies": {
    "@sthira/core": "workspace:*",
    "@sthira/persist": "workspace:*",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "keywords": [
    "chunking",
    "memory",
    "pagination",
    "virtual",
    "sthira"
  ],
  "license": "MIT"
}
