{
  "name": "@sthirajs/devtools",
  "version": "2.0.0",
  "description": "DevTools integration for sthira state manager",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sthirajs/core": ">=0.3.2"
  },
  "devDependencies": {
    "@sthirajs/core": "workspace:*",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  },
  "keywords": [
    "devtools",
    "debugging",
    "redux-devtools",
    "sthira"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/laphilosophia/sthira",
    "directory": "packages/devtools"
  }
}
