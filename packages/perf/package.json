{
  "name": "@sthirajs/perf",
  "version": "1.0.0",
  "description": "Performance utilities for Sthira state manager",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@sthirajs/core": ">=0.2.0"
  },
  "devDependencies": {
    "@sthirajs/core": "workspace:*",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "performance",
    "worker",
    "batching",
    "optimization",
    "sthira"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/laphilosophia/sthira",
    "directory": "packages/perf"
  }
}
